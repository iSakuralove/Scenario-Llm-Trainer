{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "scenario_question",
  "title": "scenario_question",
  "description": "AI generated scenario question",
  "x-version": "1.0.0",
  "x-task": "SC-03",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "description", "domain", "difficulty", "scenario_type", "tags", "content"],
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "domain": { "type": "string", "minLength": 1 },
    "difficulty": { "type": "string", "enum": ["L1", "L2", "L3", "L4", "L5"] },
    "scenario_type": { "type": "string", "enum": ["troubleshooting", "design", "performance"] },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "content": { "$ref": "#/$defs/scenario_content" }
  },
  "$defs": {
    "scenario_content": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root_cause", "root_cause_keywords", "key_evidence", "standard_procedure", "reveal_strategy", "architecture_diagram_spec"],
      "properties": {
        "root_cause": { "type": "string", "minLength": 1 },
        "root_cause_keywords": {
          "type": "array",
          "minItems": 2,
          "items": { "type": "string", "minLength": 1 }
        },
        "key_evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "standard_procedure": {
          "type": "array",
          "minItems": 2,
          "items": { "type": "string", "minLength": 1 }
        },
        "architecture_diagram": {
          "type": "string",
          "enum": [""],
          "description": "AI output must keep this empty. Backend deterministically builds final Mermaid from architecture_diagram_spec."
        },
        "architecture_diagram_spec": { "$ref": "#/$defs/diagram_spec" },
        "reference_links": {
          "type": "array",
          "items": { "type": "string" }
        },
        "reveal_strategy": { "$ref": "#/$defs/reveal_strategy" }
      }
    },
    "reveal_strategy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface_clues", "deep_clues", "distractors"],
      "properties": {
        "surface_clues": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/clue" }
        },
        "deep_clues": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/clue" }
        },
        "distractors": {
          "type": "array",
          "items": { "$ref": "#/$defs/clue" }
        }
      }
    },
    "clue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["clue_id", "trigger_keywords", "content", "is_distractor"],
      "properties": {
        "clue_id": { "type": "string", "minLength": 1 },
        "trigger_keywords": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "prerequisite_clues": {
          "type": "array",
          "items": { "type": "string" }
        },
        "content": { "type": "string", "minLength": 1 },
        "is_distractor": { "type": "boolean" },
        "recommended_next_ask": { "type": "string" }
      }
    },
    "diagram_spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["direction", "nodes", "edges"],
      "properties": {
        "direction": { "type": "string", "enum": ["TD", "LR"] },
        "nodes": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/diagram_node" }
        },
        "edges": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/diagram_edge" }
        }
      }
    },
    "diagram_node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_]{0,31}$" },
        "label": { "type": "string", "minLength": 1 }
      }
    },
    "diagram_edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to"],
      "properties": {
        "from": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_]{0,31}$" },
        "to": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_]{0,31}$" },
        "label": { "type": "string" },
        "style": { "type": "string", "enum": ["solid", "dotted"] }
      }
    }
  }
}
