{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "scenario_content_preview",
  "title": "scenario_content_preview",
  "description": "AI structured community scenario preview",
  "x-version": "1.0.0",
  "x-task": "CM-02",
  "type": "object",
  "additionalProperties": false,
  "required": ["root_cause", "key_evidence", "standard_procedure", "reveal_strategy", "architecture_diagram_spec"],
  "properties": {
    "root_cause": { "type": "string", "minLength": 1 },
    "root_cause_keywords": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "key_evidence": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "standard_procedure": {
      "type": "array",
      "minItems": 2,
      "items": { "type": "string", "minLength": 1 }
    },
    "architecture_diagram": {
      "type": "string",
      "enum": [""],
      "description": "AI output must keep this empty. Backend deterministically builds final Mermaid from architecture_diagram_spec."
    },
    "architecture_diagram_spec": { "$ref": "#/$defs/diagram_spec" },
    "diagram_status": { "type": "string", "enum": ["validated", "normalized", "generated", "fallback"] },
    "diagram_warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "reference_links": {
      "type": "array",
      "items": { "type": "string" }
    },
    "reveal_strategy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface_clues"],
      "properties": {
        "surface_clues": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/clue" }
        },
        "deep_clues": {
          "type": "array",
          "items": { "$ref": "#/$defs/clue" }
        },
        "distractors": {
          "type": "array",
          "items": { "$ref": "#/$defs/clue" }
        }
      }
    }
  },
  "$defs": {
    "clue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["clue_id", "trigger_keywords", "content"],
      "properties": {
        "clue_id": { "type": "string", "minLength": 1 },
        "trigger_keywords": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "prerequisite_clues": {
          "type": "array",
          "items": { "type": "string" }
        },
        "content": { "type": "string", "minLength": 1 },
        "is_distractor": { "type": "boolean" },
        "recommended_next_ask": { "type": "string" }
      }
    },
    "diagram_spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["direction", "nodes", "edges"],
      "properties": {
        "direction": { "type": "string", "enum": ["TD", "LR"] },
        "nodes": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/diagram_node" }
        },
        "edges": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/diagram_edge" }
        }
      }
    },
    "diagram_node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_]{0,31}$" },
        "label": { "type": "string", "minLength": 1 }
      }
    },
    "diagram_edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to"],
      "properties": {
        "from": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_]{0,31}$" },
        "to": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_]{0,31}$" },
        "label": { "type": "string" },
        "style": { "type": "string", "enum": ["solid", "dotted"] }
      }
    }
  }
}
